# Секреты — никогда не коммитить (ADR-0006).
# Паттерны каталогов якорим к корню репозитория (ведущий /), иначе они
# глотают одноимённые исходники, например src/svarog_harness/secrets/.
.env
.env.*
*.pem
*.key
*.p12
*.pfx
credentials*.json
/secrets/
/.secrets/
.svarog/secrets*

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.python-version

# Инструменты
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Локальные данные
*.sqlite3
*.db
.DS_Store

# IDE
.idea/
.vscode/
.zcode/
*.swp

# Референсные репозитории (если склонированы внутрь проекта)
reference/

# Svarog agent-home (данные агента, секреты) — не коммитить
agent-home/
